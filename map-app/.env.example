# ============================================================
# F1 Taxi — Map app environment
# Copy this file to ".env" and fill in your two keys.
# NEVER commit the real .env (it is git-ignored).
# ============================================================

# 1) BROWSER key — used client-side to load the Maps JavaScript API.
#    In Google Cloud Console, restrict it:
#      • Application restriction: HTTP referrers
#          https://yourdomain.com/*   (and http://localhost:3000/* for dev)
#      • API restriction: Maps JavaScript API  ONLY
#    It is visible in the browser by design; the referrer lock makes it
#    useless on any other site.
MAPS_BROWSER_KEY=

# 2) SERVER key — used ONLY inside this backend for Places web-service calls.
#    Restrict it:
#      • Application restriction: IP addresses  (your server's public IP)
#      • API restriction: Places API  ONLY
#    This key never reaches the browser.
GOOGLE_SERVER_KEY=

# Optional: bias/limit place search to these countries (comma-separated ISO codes)
PLACES_COUNTRIES=al,xk

# Port the server listens on
PORT=3000
